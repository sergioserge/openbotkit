---
import Terminal from './Terminal.astro';
---

<section id="get-started" class="mx-auto max-w-2xl border-t border-border px-6 py-20">
  <h2 class="text-[1.4rem] font-semibold leading-[1.7] tracking-[0.02em] text-heading">
    Get started
  </h2>

  <p class="mt-4 text-[1.25rem] leading-[1.7] text-paragraph">
    Single Go binary. Runs on macOS and Linux.
  </p>

  <div class="mt-8">
    <Terminal>
      <div>
        <span class="text-[#28c840]">$</span>
        <span class="text-[#e0e0e0]"> curl -fsSL https://raw.githubusercontent.com/73ai/openbotkit/master/install.sh | sh</span>
      </div>
      <div>
        <span class="text-[#28c840]">$</span>
        <span class="text-[#e0e0e0]"> obk setup</span>
      </div>
    </Terminal>
  </div>

  <p class="mt-8 text-[1.1rem] leading-[1.7] text-muted">
    See <a href="/capabilities" class="text-link underline">what it can do</a> or
    <a
      href="https://github.com/73ai/openbotkit"
      target="_blank"
      rel="noopener"
      class="text-link underline"
    >
      view the source on GitHub</a
    >.
  </p>

  <div class="mt-16 border-t border-border pt-12">
    <h2 class="text-[1.4rem] font-semibold leading-[1.7] tracking-[0.02em] text-heading">
      Support the research
    </h2>
    <p class="mt-4 text-[1.25rem] leading-[1.7] text-paragraph">
      If you find OpenBotKit useful, the easiest way to support this research is to
      <a
        href="https://github.com/73ai/openbotkit"
        target="_blank"
        rel="noopener"
        class="text-link underline"
      >star it on GitHub</a>. It helps others discover the project.
    </p>
  </div>
</section>
